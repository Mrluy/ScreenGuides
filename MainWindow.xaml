<Window x:Class="ScreenGuides.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="屏幕辅助线"
        Width="430"
        Height="1100"
        Icon="Assets/ScreenGuides.ico"
        MinWidth="400"
        MinHeight="760"
        WindowStartupLocation="Manual"
        Topmost="True"
        Background="#111827"
        Foreground="#F8FAFC"
        FontFamily="Segoe UI, Microsoft YaHei UI">
    <Window.Resources>
        <SolidColorBrush x:Key="PanelBg" Color="#111827" />
        <SolidColorBrush x:Key="CardBg" Color="#182233" />
        <SolidColorBrush x:Key="ControlBg" Color="#111827" />
        <SolidColorBrush x:Key="BorderSoft" Color="#2A3547" />
        <SolidColorBrush x:Key="BorderHot" Color="#3A4C63" />
        <SolidColorBrush x:Key="TextMain" Color="#F8FAFC" />
        <SolidColorBrush x:Key="TextMuted" Color="#9CA9BA" />
        <SolidColorBrush x:Key="Accent" Color="#4FC3F7" />
        <SolidColorBrush x:Key="AccentStrong" Color="#22B8F8" />

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBg}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="9" />
            <Setter Property="Padding" Value="14" />
            <Setter Property="Margin" Value="0,0,0,14" />
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextMain}" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="SectionIconStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource Accent}" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,0,10,0" />
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextMain}" />
            <Setter Property="FontSize" Value="13" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Height" Value="36" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="Background" Value="{StaticResource ControlBg}" />
            <Setter Property="Foreground" Value="{StaticResource TextMain}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="CaretBrush" Value="{StaticResource Accent}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="0" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource Accent}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Border" Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="36" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="Background" Value="{StaticResource ControlBg}" />
            <Setter Property="Foreground" Value="{StaticResource TextMain}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="MaxDropDownHeight" Value="260" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Focusable="False"
                                          ClickMode="Press"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="Border"
                                                Background="{Binding Background, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                BorderBrush="{Binding BorderBrush, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                BorderThickness="{Binding BorderThickness, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                CornerRadius="7">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="24" />
                                                </Grid.ColumnDefinitions>
                                                <ContentPresenter Margin="{Binding Padding, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                                  HorizontalAlignment="Stretch"
                                                                  VerticalAlignment="Center"
                                                                  Content="{Binding SelectionBoxItem, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                                  ContentTemplate="{Binding ItemTemplate, RelativeSource={RelativeSource AncestorType=ComboBox}}" />
                                                <TextBlock Grid.Column="1"
                                                           Text="⌄"
                                                           FontSize="16"
                                                           Foreground="{StaticResource TextMuted}"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center" />
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource BorderHot}" />
                                            </Trigger>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource Accent}" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>

                            <Popup x:Name="PART_Popup"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom"
                                   PopupAnimation="Fade">
                                <Border MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                        Margin="0,4,0,0"
                                        Background="#111827"
                                        BorderBrush="{StaticResource BorderSoft}"
                                        BorderThickness="1"
                                        CornerRadius="7">
                                    <ScrollViewer Margin="4" CanContentScroll="True">
                                        <ItemsPresenter />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{StaticResource TextMain}" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemBorder"
                                Background="Transparent"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#213047" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#1E3A50" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="36" />
            <Setter Property="MinWidth" Value="86" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="Background" Value="{StaticResource Accent}" />
            <Setter Property="Foreground" Value="#062033" />
            <Setter Property="BorderBrush" Value="{StaticResource Accent}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{StaticResource AccentStrong}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Border" Property="Opacity" Value="0.82" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Border" Property="Opacity" Value="0.5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="36" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="Background" Value="#1B2638" />
            <Setter Property="Foreground" Value="{StaticResource TextMain}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource Accent}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Border" Property="Opacity" Value="0.78" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GhostButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="Foreground" Value="{StaticResource Accent}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="8,0" />
            <Setter Property="MinWidth" Value="44" />
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextMain}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid Cursor="Hand">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="26" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border x:Name="Box"
                                    Width="18"
                                    Height="18"
                                    CornerRadius="5"
                                    Background="#111827"
                                    BorderBrush="#536175"
                                    BorderThickness="1"
                                    VerticalAlignment="Center">
                                <TextBlock x:Name="CheckMark"
                                           Text="✓"
                                           FontSize="13"
                                           FontWeight="Bold"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Foreground="White"
                                           Visibility="Collapsed" />
                            </Border>
                            <ContentPresenter Grid.Column="1"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Box" Property="Background" Value="{StaticResource Accent}" />
                                <Setter TargetName="Box" Property="BorderBrush" Value="{StaticResource Accent}" />
                                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Box" Property="BorderBrush" Value="{StaticResource Accent}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SliderThumbStyle" TargetType="Thumb">
            <Setter Property="Width" Value="16" />
            <Setter Property="Height" Value="16" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Ellipse Fill="{StaticResource Accent}" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Slider">
            <Setter Property="Height" Value="24" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid Height="24" VerticalAlignment="Center">
                            <Track x:Name="PART_Track" VerticalAlignment="Center">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="Slider.DecreaseLarge">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="4"
                                                        CornerRadius="2"
                                                        Background="{StaticResource Accent}" />
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="Slider.IncreaseLarge">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="4"
                                                        CornerRadius="2"
                                                        Background="#425066" />
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource SliderThumbStyle}" />
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ListBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{StaticResource TextMain}" />
        </Style>

        <Style TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,0,7" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <ContentPresenter />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  CanContentScroll="False"
                  PanningMode="VerticalOnly">
        <StackPanel Margin="16">
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Image Width="42"
                       Height="42"
                       Source="Assets/ScreenGuides.ico"
                       Margin="0,2,12,0" />
                <StackPanel Grid.Column="1">
                    <TextBlock Text="屏幕辅助线"
                               FontSize="24"
                               FontWeight="SemiBold" />
                    <TextBlock Text="固定屏幕参考线 / 对齐线"
                               Margin="0,4,0,0"
                               FontSize="13"
                               Foreground="{StaticResource TextMuted}" />
                    <TextBlock Text="v0.1.0 测试版"
                               Margin="0,6,0,0"
                               FontSize="12"
                               Foreground="{StaticResource Accent}" />
                </StackPanel>
                <Button Grid.Column="2"
                        Content="隐藏"
                        Width="76"
                        Margin="12,4,0,0"
                        VerticalAlignment="Top"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Click="HidePanel_Click" />
            </Grid>

            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <DockPanel Margin="0,0,0,12">
                        <TextBlock Text="&#xE7F4;" Style="{StaticResource SectionIconStyle}" />
                        <TextBlock Text="当前屏幕" Style="{StaticResource SectionTitleStyle}" />
                    </DockPanel>

                    <ComboBox x:Name="ScreenSelector"
                              SelectionChanged="ScreenSelector_SelectionChanged"
                              Margin="0,0,0,10">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding Title}"
                                               FontSize="14"
                                               Foreground="{StaticResource TextMain}" />
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding ResolutionText}"
                                               FontSize="13"
                                               Foreground="{StaticResource TextMuted}"
                                               Margin="16,0,0,0" />
                                </Grid>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <DockPanel Margin="0,0,0,10">
                        <TextBlock Text="&#xE946;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="15"
                                   Foreground="{StaticResource TextMuted}"
                                   Margin="0,0,8,0" />
                        <TextBlock x:Name="ScreenStatusText"
                                   TextWrapping="Wrap"
                                   Foreground="{StaticResource TextMuted}" />
                    </DockPanel>

                    <CheckBox Content="跨越所有屏幕"
                              IsChecked="{Binding SpanAcrossScreensForNewGuides, Mode=TwoWay}" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <DockPanel Margin="0,0,0,12">
                        <TextBlock Text="&#xE710;" Style="{StaticResource SectionIconStyle}" />
                        <TextBlock Text="添加参考线" Style="{StaticResource SectionTitleStyle}" />
                    </DockPanel>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button Content="+  竖线"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Click="AddVertical_Click" />
                        <Button Grid.Column="2"
                                Content="+  横线"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Click="AddHorizontal_Click" />
                    </Grid>

                    <Button Content="⌖  屏幕居中十字"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Click="AddCenterCross_Click" />

                    <TextBlock x:Name="AddStatusText"
                               Margin="0,10,0,0"
                               FontSize="12"
                               TextWrapping="Wrap"
                               Foreground="{StaticResource TextMuted}" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <DockPanel Margin="0,0,0,12">
                        <TextBlock Text="&#xE890;" Style="{StaticResource SectionIconStyle}" />
                        <TextBlock Text="显示设置" Style="{StaticResource SectionTitleStyle}" />
                    </DockPanel>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <CheckBox Content="显示参考线"
                                      IsChecked="{Binding IsOverlayVisible, Mode=TwoWay}" />
                            <CheckBox Content="锁定并鼠标穿透"
                                      IsChecked="{Binding IsLocked, Mode=TwoWay}" />
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <CheckBox Content="显示坐标"
                                      IsChecked="{Binding ShowCoordinates, Mode=TwoWay}" />
                            <CheckBox Content="吸附整数坐标"
                                      IsChecked="{Binding SnapToInteger, Mode=TwoWay}" />
                        </StackPanel>
                    </Grid>

                    <Grid Margin="0,2,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="58" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="颜色"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource TextMain}" />
                        <ComboBox Grid.Column="1"
                                  Width="146"
                                  HorizontalAlignment="Left"
                                  SelectedValue="{Binding LineColor, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  SelectedValuePath="Tag">
                            <ComboBoxItem Tag="#00C7D9">
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="12" Height="12" Fill="#00C7D9" Margin="0,0,8,0" />
                                    <TextBlock Text="青色" />
                                </StackPanel>
                            </ComboBoxItem>
                            <ComboBoxItem Tag="#FF4D8D">
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="12" Height="12" Fill="#FF4D8D" Margin="0,0,8,0" />
                                    <TextBlock Text="粉色" />
                                </StackPanel>
                            </ComboBoxItem>
                            <ComboBoxItem Tag="#FFD166">
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="12" Height="12" Fill="#FFD166" Margin="0,0,8,0" />
                                    <TextBlock Text="黄色" />
                                </StackPanel>
                            </ComboBoxItem>
                            <ComboBoxItem Tag="#54D17A">
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="12" Height="12" Fill="#54D17A" Margin="0,0,8,0" />
                                    <TextBlock Text="绿色" />
                                </StackPanel>
                            </ComboBoxItem>
                            <ComboBoxItem Tag="#FFFFFF">
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="12" Height="12" Fill="#FFFFFF" Margin="0,0,8,0" />
                                    <TextBlock Text="白色" />
                                </StackPanel>
                            </ComboBoxItem>
                        </ComboBox>
                    </Grid>

                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="58" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="56" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="透明度" VerticalAlignment="Center" />
                        <Slider Grid.Column="1"
                                Minimum="0.2"
                                Maximum="1"
                                Value="{Binding LineOpacity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Grid.Column="2"
                                   Text="{Binding LineOpacity, StringFormat={}{0:P0}}"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource TextMuted}" />
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="58" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="56" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="粗细" VerticalAlignment="Center" />
                        <Slider Grid.Column="1"
                                Minimum="1"
                                Maximum="4"
                                Value="{Binding LineThickness, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Grid.Column="2"
                                   Text="{Binding LineThickness, StringFormat={}{0:0.0} px}"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource TextMuted}" />
                    </Grid>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <DockPanel Margin="0,0,0,12">
                        <TextBlock Text="&#xE718;" Style="{StaticResource SectionIconStyle}" />
                        <TextBlock Text="固定参考线" Style="{StaticResource SectionTitleStyle}" />
                        <Button DockPanel.Dock="Right"
                                Content="清空"
                                Height="28"
                                Style="{StaticResource GhostButtonStyle}"
                                Click="ClearGuides_Click" />
                    </DockPanel>

                    <ListBox ItemsSource="{Binding Guides}"
                             MaxHeight="250"
                             ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListBox.Style>
                            <Style TargetType="ListBox" BasedOn="{StaticResource {x:Type ListBox}}">
                                <Style.Triggers>
                                    <Trigger Property="HasItems" Value="False">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListBox">
                                                    <Border Height="44"
                                                            CornerRadius="7"
                                                            BorderBrush="{StaticResource BorderSoft}"
                                                            BorderThickness="1"
                                                            Background="#131D2C">
                                                        <TextBlock Text="暂无固定参考线"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"
                                                                   Foreground="{StaticResource TextMuted}" />
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ListBox.Style>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border CornerRadius="7"
                                        BorderBrush="{StaticResource BorderSoft}"
                                        BorderThickness="1"
                                        Background="#131D2C"
                                        Padding="10,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="22" />
                                            <ColumnDefinition Width="58" />
                                            <ColumnDefinition Width="24" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="32" />
                                            <ColumnDefinition Width="32" />
                                        </Grid.ColumnDefinitions>
                                        <Grid Width="16" Height="20" VerticalAlignment="Center">
                                            <Border x:Name="GuideMark"
                                                    Width="3"
                                                    Height="20"
                                                    CornerRadius="2"
                                                    Background="{StaticResource Accent}"
                                                    HorizontalAlignment="Center" />
                                        </Grid>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding OrientationText}"
                                                   FontWeight="SemiBold"
                                                   VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding CoordinateAxis}"
                                                   Foreground="{StaticResource TextMuted}"
                                                   VerticalAlignment="Center" />
                                        <TextBox Grid.Column="3"
                                                 Text="{Binding RelativePosition, Mode=TwoWay, UpdateSourceTrigger=LostFocus, StringFormat={}{0:0.#}}"
                                                 Height="30"
                                                 Margin="0,0,10,0" />
                                        <TextBlock Grid.Column="4"
                                                   Text="&#xE72E;"
                                                   FontFamily="Segoe MDL2 Assets"
                                                   FontSize="15"
                                                   Foreground="{StaticResource Accent}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" />
                                        <Button Grid.Column="5"
                                                Tag="{Binding}"
                                                Style="{StaticResource GhostButtonStyle}"
                                                ToolTip="删除"
                                                Click="DeleteGuide_Click">
                                            <TextBlock Text="&#xE74D;"
                                                       FontFamily="Segoe MDL2 Assets"
                                                       FontSize="15"
                                                       Foreground="{StaticResource TextMuted}" />
                                        </Button>
                                    </Grid>
                                </Border>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding OrientationText}" Value="横线">
                                        <Setter TargetName="GuideMark" Property="Width" Value="18" />
                                        <Setter TargetName="GuideMark" Property="Height" Value="3" />
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </Border>

            <Border Background="{StaticResource CardBg}"
                    BorderBrush="{StaticResource BorderSoft}"
                    BorderThickness="1"
                    CornerRadius="9"
                    Padding="12"
                    Margin="0,0,0,14">
                <DockPanel>
                    <TextBlock Text="&#xE765;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="16"
                               Foreground="{StaticResource TextMuted}"
                               Margin="0,0,10,0" />
                    <TextBlock x:Name="HotkeyStatusText"
                               TextWrapping="Wrap"
                               Foreground="{StaticResource TextMuted}" />
                </DockPanel>
            </Border>

            <Button Content="退出"
                    Width="92"
                    Margin="0,0,0,4"
                    HorizontalAlignment="Left"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Click="Exit_Click" />
        </StackPanel>
    </ScrollViewer>
</Window>
