<Window x:Class="ScreenGuides.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="屏幕辅助线工具"
        Width="430"
        Height="660"
        Icon="Assets/ScreenGuides.ico"
        MinWidth="400"
        MinHeight="560"
        WindowStartupLocation="Manual"
        Topmost="True"
        Background="{StaticResource PanelBackgroundBrush}"
        Foreground="{StaticResource PanelTextBrush}">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="Margin" Value="0,0,8,8" />
            <Setter Property="Background" Value="#323A45" />
            <Setter Property="Foreground" Value="{StaticResource PanelTextBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Height" Value="32" />
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="Background" Value="#11161C" />
            <Setter Property="Foreground" Value="{StaticResource PanelTextBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Margin" Value="0,0,0,9" />
            <Setter Property="Foreground" Value="{StaticResource PanelTextBrush}" />
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource PanelTextBrush}" />
        </Style>
        <Style TargetType="Slider">
            <Setter Property="Margin" Value="0,2,0,12" />
        </Style>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  CanContentScroll="False"
                  PanningMode="VerticalOnly">
        <StackPanel Margin="16">

        <DockPanel Grid.Row="0" Margin="0,0,0,14">
            <Button DockPanel.Dock="Right"
                    Width="68"
                    Content="隐藏"
                    Click="HidePanel_Click" />
            <StackPanel>
                <TextBlock Text="屏幕辅助线工具"
                           FontSize="22"
                           FontWeight="SemiBold" />
                <TextBlock Text="固定屏幕参考线 / 对齐线"
                           Margin="0,3,0,0"
                           Foreground="{StaticResource MutedTextBrush}" />
            </StackPanel>
        </DockPanel>

        <Border Grid.Row="1"
                Padding="12"
                Margin="0,0,0,12"
                BorderBrush="{StaticResource PanelBorderBrush}"
                BorderThickness="1"
                CornerRadius="6"
                Background="#1C2128">
            <StackPanel>
                <TextBlock Text="添加固定参考线"
                           FontWeight="SemiBold"
                           Margin="0,0,0,10" />

                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="64" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="目标屏幕"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource MutedTextBrush}" />
                    <ComboBox x:Name="ScreenSelector"
                              Grid.Column="1"
                              DisplayMemberPath="DisplayName"
                              SelectionChanged="ScreenSelector_SelectionChanged"
                              Margin="0,0,8,0" />
                    <Button Grid.Column="2"
                            Content="当前屏幕"
                            Margin="0"
                            Click="UseCurrentScreen_Click" />
                </Grid>

                <TextBlock x:Name="ScreenStatusText"
                           FontSize="12"
                           TextWrapping="Wrap"
                           Foreground="{StaticResource MutedTextBrush}"
                           Margin="0,0,0,10" />

                <CheckBox Content="跨越所有屏幕"
                          IsChecked="{Binding SpanAcrossScreensForNewGuides, Mode=TwoWay}"
                          Margin="0,0,0,10" />

                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="64" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="屏内 X"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource MutedTextBrush}" />
                    <TextBox x:Name="VerticalPositionBox"
                             Grid.Column="1"
                             Margin="0,0,8,0" />
                    <Button Grid.Column="2"
                            Content="添加竖线"
                            Margin="0"
                            Click="AddVertical_Click" />
                </Grid>

                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="64" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="屏内 Y"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource MutedTextBrush}" />
                    <TextBox x:Name="HorizontalPositionBox"
                             Grid.Column="1"
                             Margin="0,0,8,0" />
                    <Button Grid.Column="2"
                            Content="添加横线"
                            Margin="0"
                            Click="AddHorizontal_Click" />
                </Grid>

                <WrapPanel>
                    <Button Content="屏幕居中十字"
                            Click="AddCenterCross_Click" />
                    <Button Content="清空"
                            Click="ClearGuides_Click" />
                </WrapPanel>
                <TextBlock x:Name="AddStatusText"
                           FontSize="12"
                           TextWrapping="Wrap"
                           Foreground="{StaticResource MutedTextBrush}" />
            </StackPanel>
        </Border>

        <Border Grid.Row="2"
                Padding="12"
                Margin="0,0,0,12"
                BorderBrush="{StaticResource PanelBorderBrush}"
                BorderThickness="1"
                CornerRadius="6"
                Background="#1C2128">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,14,0">
                    <CheckBox Content="显示参考线"
                              IsChecked="{Binding IsOverlayVisible, Mode=TwoWay}" />
                    <CheckBox Content="锁定并鼠标穿透"
                              IsChecked="{Binding IsLocked, Mode=TwoWay}" />
                    <CheckBox Content="显示坐标"
                              IsChecked="{Binding ShowCoordinates, Mode=TwoWay}" />
                    <CheckBox Content="吸附整数坐标"
                              IsChecked="{Binding SnapToInteger, Mode=TwoWay}" />
                </StackPanel>

                <StackPanel Grid.Column="1">
                    <TextBlock Text="颜色"
                               FontWeight="SemiBold"
                               Margin="0,0,0,6" />
                    <ComboBox SelectedValue="{Binding LineColor, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              SelectedValuePath="Tag"
                              Margin="0,0,0,12">
                        <ComboBoxItem Tag="#00C7D9" Content="青色" />
                        <ComboBoxItem Tag="#FF4D8D" Content="粉色" />
                        <ComboBoxItem Tag="#FFD166" Content="黄色" />
                        <ComboBoxItem Tag="#54D17A" Content="绿色" />
                        <ComboBoxItem Tag="#FFFFFF" Content="白色" />
                    </ComboBox>

                    <DockPanel>
                        <TextBlock Text="透明度" DockPanel.Dock="Left" />
                        <TextBlock Text="{Binding LineOpacity, StringFormat={}{0:P0}}"
                                   DockPanel.Dock="Right"
                                   Foreground="{StaticResource MutedTextBrush}" />
                    </DockPanel>
                    <Slider Minimum="0.2"
                            Maximum="1"
                            Value="{Binding LineOpacity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                    <DockPanel>
                        <TextBlock Text="粗细" DockPanel.Dock="Left" />
                        <TextBlock Text="{Binding LineThickness, StringFormat={}{0:0.0}px}"
                                   DockPanel.Dock="Right"
                                   Foreground="{StaticResource MutedTextBrush}" />
                    </DockPanel>
                    <Slider Minimum="1"
                            Maximum="4"
                            Value="{Binding LineThickness, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="3"
                Padding="12"
                BorderBrush="{StaticResource PanelBorderBrush}"
                BorderThickness="1"
                CornerRadius="6"
                Background="#1C2128">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top"
                           Text="固定参考线"
                           FontWeight="SemiBold"
                           Margin="0,0,0,8" />
                <ListBox ItemsSource="{Binding Guides}"
                         MaxHeight="260"
                         Background="#11161C"
                         BorderBrush="{StaticResource PanelBorderBrush}"
                         Foreground="{StaticResource PanelTextBrush}"
                         ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="4">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="58" />
                                    <ColumnDefinition Width="24" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding OrientationText}"
                                           VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1"
                                           Text="{Binding CoordinateAxis}"
                                           VerticalAlignment="Center"
                                           Foreground="{StaticResource MutedTextBrush}" />
                                <TextBox Grid.Column="2"
                                         Text="{Binding RelativePosition, Mode=TwoWay, UpdateSourceTrigger=LostFocus, StringFormat={}{0:0.#}}"
                                         Margin="0,0,8,0" />
                                <Button Grid.Column="3"
                                        Content="删除"
                                        MinHeight="30"
                                        Padding="9,3"
                                        Margin="0"
                                        Tag="{Binding}"
                                        Click="DeleteGuide_Click" />
                                <TextBlock Grid.Row="1"
                                           Grid.ColumnSpan="4"
                                           Text="{Binding SpanText}"
                                           FontSize="11"
                                           Margin="0,4,0,0"
                                           Foreground="{StaticResource MutedTextBrush}" />
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <StackPanel Grid.Row="4" Margin="0,12,0,0">
            <TextBlock x:Name="HotkeyStatusText"
                       TextWrapping="Wrap"
                       Foreground="{StaticResource MutedTextBrush}"
                       FontSize="12" />
            <WrapPanel Margin="0,10,0,0">
                <Button Content="退出"
                        Width="80"
                        Click="Exit_Click" />
            </WrapPanel>
        </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Window>
